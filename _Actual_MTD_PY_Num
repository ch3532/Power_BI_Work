_Actual_MTD_PY_Num = 
VAR CurrentPLLine = SELECTEDVALUE('P&L Rows'[PL_Line])
VAR IsSectionHeader =
    IF(ISBLANK(CurrentPLLine), FALSE(),
        CALCULATE(SELECTEDVALUE(DimPL_Line[IsSectionHeader], FALSE()), REMOVEFILTERS(DimPL_Line), DimPL_Line[PL_Line] = CurrentPLLine))
VAR FeesMTDPY = CALCULATE([_Actual_Line_MTD_PY], REMOVEFILTERS('P&L Rows'), 'P&L Rows'[Row Number] = "PL197")
VAR TaxInsMTDPY = CALCULATE([_Actual_Line_MTD_PY], REMOVEFILTERS('P&L Rows'), 'P&L Rows'[Row Number] = "PL207")
VAR RentMTDPY = CALCULATE([_Actual_Line_MTD_PY], REMOVEFILTERS('P&L Rows'), 'P&L Rows'[Row Number] = "PL208")
VAR NonContMTDPY = FeesMTDPY + TaxInsMTDPY + RentMTDPY
RETURN
    IF(IsSectionHeader, BLANK(),
        IF(CurrentPLLine = "Total Non-Controllable Expenses", NonContMTDPY, [_Actual_Line_MTD_PY]))
