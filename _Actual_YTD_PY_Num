_Actual_YTD_PY_Num = 
VAR CurrentPLLine = SELECTEDVALUE('P&L Rows'[PL_Line])
VAR IsSectionHeader =
    IF(ISBLANK(CurrentPLLine), FALSE(),
        CALCULATE(SELECTEDVALUE(DimPL_Line[IsSectionHeader], FALSE()), REMOVEFILTERS(DimPL_Line), DimPL_Line[PL_Line] = CurrentPLLine))
VAR FeesYTDPY = CALCULATE([_Actual_Line_YTD_PY], REMOVEFILTERS('P&L Rows'), 'P&L Rows'[Row Number] = "PL197")
VAR TaxInsYTDPY = CALCULATE([_Actual_Line_YTD_PY], REMOVEFILTERS('P&L Rows'), 'P&L Rows'[Row Number] = "PL207")
VAR RentYTDPY = CALCULATE([_Actual_Line_YTD_PY], REMOVEFILTERS('P&L Rows'), 'P&L Rows'[Row Number] = "PL208")
VAR NonContYTDPY = FeesYTDPY + TaxInsYTDPY + RentYTDPY
RETURN
    IF(IsSectionHeader, BLANK(),
        IF(CurrentPLLine = "Total Non-Controllable Expenses", NonContYTDPY, [_Actual_Line_YTD_PY]))
